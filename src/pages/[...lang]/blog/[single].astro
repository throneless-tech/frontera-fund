---
import Base from "@/layouts/Base.astro";
import BlogSingle from "@/components/BlogSingle.astro";
import Breadcrumbs from "@/components/widgets/Breadcrumbs.astro";

export const prerender = false;

// fetch page data
const response = await fetch(`${import.meta.env.PUBLIC_API_URL || "https://localhost:3000" }/api/posts?depth=2&draft=false&locale=${Astro.currentLocale}&trash=false`)

const data = await response.json()

const slug = Astro.url.pathname.replaceAll('/', '');

const post = data.docs.find((p: any) => p.slug === slug);

if (!post) return Astro.redirect("/404");

---

<Base {...post} hasHeaderDarkBackground={true}>
  <Breadcrumbs breadcrumbExcludedPaths={["Blog"]} />
  <BlogSingle content={post} />
</Base>
