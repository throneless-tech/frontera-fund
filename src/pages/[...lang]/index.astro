---
import Base from "@/layouts/Base.astro";
import Banner from "@/components/sections/Banner.astro";
import CTASection from "@/components/sections/CTASection.astro";
import ServicesSection from "@/components/sections/ServicesSection.astro";
import BlogSection from "@/components/sections/BlogSection.astro";

export const prerender = false;

// fetch homepage data
const res = await fetch(`${import.meta.env.PUBLIC_API_URL || "https://localhost:3000" }/api/globals/homepage?depth=2&draft=false&locale=${Astro.currentLocale}&trash=false`)

const resPosts = await fetch(`${import.meta.env.PUBLIC_API_URL || "https://localhost:3000" }/api/posts?depth=1&draft=false&locale=${Astro.currentLocale}&trash=false&limit=4`)

const data = await res?.json()

const posts = await resPosts?.json()

if (!data) return Astro.redirect("/404");

---

<Base {...data} headerPosition="sticky" hasHeaderDarkBackground={true}>
  <Banner content={data?.hero} />
  <ServicesSection services={data?.offers} />
  <CTASection content={data?.CTA} />
  <BlogSection posts={posts.docs}  />
</Base>
