---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import Clients from "@/components/sections/Clients.astro";
import { getEntryCTM } from "@/lib/customContentLoader.astro";
import Banner from "@/components/sections/Banner.astro";
import CTASection from "@/components/sections/CTASection.astro";
import ServicesSection from "@/components/sections/ServicesSection.astro";
import BlogSection from "@/components/sections/BlogSection.astro";

export const prerender = false;

const page = await getEntryCTM("homepage", "-index", Astro.currentLocale);

let data;
let err;

try {
  // fetch homepage data
  const res = await fetch(`${import.meta.env.PUBLIC_API_URL || "https://localhost:3000" }/api/globals/homepage?depth=2&draft=false&locale=${Astro.currentLocale}&trash=false`)

  data = await res?.json()
  
} catch (e) {
  err = e;
}

if (err) {
  console.log(`An error occurred: ${err}`);
}
---

<Base {...page?.data} headerPosition="sticky" hasHeaderDarkBackground={true}>
  <Banner content={data?.hero} />
  <ServicesSection services={data?.offers} />
  <CTASection content={data?.CTA} />
  <!-- <Clients /> -->
  <BlogSection />
</Base>
