---
import type { z } from "astro/zod";
import { getEntryCTM } from "@/lib/customContentLoader.astro";
import { markdownify } from "@/lib/utils/textConverter";
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import type { CTASectionSchema } from "@/sections.schema";
import CTACard from "@/layouts/components/cards/CTACard.astro";

// Type for this section data
type CTASectionSchema = NonNullable<z.infer<typeof CTASectionSchema>>;

type Props = {
  content?: CTASectionSchema;
};

const { content } = Astro.props

---

<section id="contact" class="bg-primary pb-20 md:pb-30">
  <div class="container space-y-14">
    <div class="container">
      <CTACard content={content} />
    </div>
  </div>
</section>
