---
interface Props {
  class?: string;
  initiallyOpen?: boolean;
  id: string;
  size?: "sm" | "md" | "lg";
  showDefault?: boolean;
  direction?: "left" | "right";
}

const {
  class: ClassName,
  initiallyOpen = false,
  id,
  direction = "left",
  size = "sm",
} = Astro.props;
---

<div
  id={id}
  class:list={[
    "offcanvas hs-overlay fixed z-50 h-full w-full transform bg-white transition-all duration-300",
    direction === "left"
      ? initiallyOpen
        ? "inset-s-0 top-0 translate-x-0"
        : "hs-overlay-open:translate-x-0 inset-s-0 top-0 -translate-x-full"
      : initiallyOpen
        ? "inset-e-0 top-0 translate-x-0"
        : "hs-overlay-open:translate-x-0 inset-e-0 top-0 translate-x-full md:translate-x-[150%]",
    size === "sm" && "max-w-lg",
    size === "md" && "max-w-xl",
    size === "lg" && "max-w-2xl",
    ClassName,
  ]}
  role="dialog"
  tabindex="-1"
  aria-labelledby={id + "-label"}>
  <slot />
  <div id={id + "-label"} class="sr-only">Off-canvas menu</div>
</div>
