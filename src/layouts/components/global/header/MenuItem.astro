---
import type { NavigationLink } from "@/types";
import { getLocaleUrlCTM } from "@/lib/utils/i18nUtils";

const menu = Astro.props.menu;
const { pathname } = Astro.url;

---

{
  <li class="nav-item" role="menuitem">
    <a
      {...{
        // Set `rel` attribute for external links or use provided value
        rel: menu.link.url?.startsWith("http")
          ? menu.link.newTab || "noopener noreferrer"
          : menu.link.newTab || undefined,

        // Set `target` to "_blank" for external links unless otherwise specified
        target: menu.link.url?.startsWith("http")
          ? menu.target || "_blank"
          : menu.target || undefined,
      }}
      target={menu.link.url?.startsWith("http") ? "_blank" : undefined}
      href={getLocaleUrlCTM(
        menu.link.url || Astro.url.origin,
        Astro.currentLocale,
      )}
      class:list={[
        "nav-link",
        {
          "nav-link-active":
            pathname === `${menu.link.url}/` || pathname === menu.link.url,
        },
      ]}>
      {menu.link.label}
    </a>
  </li>
}
