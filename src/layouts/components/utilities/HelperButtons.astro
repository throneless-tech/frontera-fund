---
import ReactIcons from "@/helpers/ReactIcons.astro";
import CustomButton from "../CustomButton.astro";
---

<div
  class="action-buttons pointer-events-none fixed end-0 bottom-5 z-100 mb-8 flex flex-col items-end space-y-2 opacity-0 transition-all duration-300 [&.scroll-down]:pointer-events-auto [&.scroll-down]:end-5 [&.scroll-down]:opacity-100">
  <div class="bg-primary p-4 mb-8 shadow-xl rounded-lg text-light text-xl ">
    <div class="flex items-center justify-start gap-2">
      <ReactIcons icon="FaPhoneAlt" />
      Call the helpline 24/7:
    </div>
    <div class="text-center">
      <a class="underline" href="tel:+19568870706">
        (956) 887-0706
      </a>
    </div>
  </div>
  <CustomButton
    label="Quick exit"
    hoverEffect="creative-fill"
    url="https://www.weather.com"
    class="effect-color-salmon btn-accent drop-shadow-2xl drop-shadow-white/10"
  />
  <!-- <CustomButton
    label="Download Now"
    hoverEffect="creative-fill"
    url="https://getastrothemes.com/astro-themes/folex-lite/"
    class="effect-color-accent btn-primary drop-shadow-2xl drop-shadow-white/10"
  /> -->

  <script>
    function actionBtns(): void {
      const btns = document.querySelector(
        ".action-buttons",
      ) as HTMLElement | null;
      if (!btns) return;

      window.addEventListener("scroll", () => {
        const scrollTop = window.scrollY;
        const scrollBottom = scrollTop + window.innerHeight;
        const pageHeight = document.documentElement.scrollHeight;

        // Check if near the top (within 200px)
        const nearTop = scrollTop <= 200;

        // Check if near the bottom (within 200px of the end)
        const nearBottom = scrollBottom >= pageHeight - 200;

        if (nearTop || nearBottom) {
          btns.classList.remove("scroll-down");
        } else {
          btns.classList.add("scroll-down");
        }
      });
    }

    actionBtns();
  </script>
</div>
